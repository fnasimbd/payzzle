<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1774899004936-1" author="fnasi">
        <createTable tableName="merchant">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_merchant"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="settings" type="jsonb"/>
        </createTable>
    </changeSet>
    <changeSet id="1774899004936-2" author="fnasi">
        <createTable tableName="transaction">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_transaction"/>
            </column>
            <column name="merchant_id" type="BIGINT"/>
            <column name="transaction_id" type="VARCHAR(255)"/>
            <column name="amount" type="INT"/>
            <column name="currency" type="VARCHAR(255)"/>
            <column name="timeout" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1774899004936-3" author="fnasi">
        <addForeignKeyConstraint baseColumnNames="merchant_id" baseTableName="transaction"
                                 constraintName="FK_TRANSACTION_ON_MERCHANT" referencedColumnNames="id"
                                 referencedTableName="merchant"/>
    </changeSet>

</databaseChangeLog>